{
  "productName": "MarkLume",
  "version": "1.0.0",
  "identifier": "com.marklume.app",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "file://../marklume.html",
    "beforeBuildCommand": "",
    "frontendDist": "../marklume.html"
  },
  "app": {
    "windows": [
      {
        "title": "MarkLume",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
