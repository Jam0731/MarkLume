{
  "identifier": "default",
  "description": "Default capabilities for MarkLume",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-read-dir",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-appdata-exists",
    "fs:allow-appdata-mkdir",
    "fs:allow-appdata-remove"
  ]
}
